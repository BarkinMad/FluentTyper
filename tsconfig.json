{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "outDir": "./build",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "allowJs": true, // Allow JavaScript files to be compiled
    "checkJs": false,
    "lib": ["DOM", "ES2022"],
    "moduleResolution": "bundler",
    "sourceMap": false,
    "typeRoots": [ "node_modules/@types" ]
  },
  "include": ["src/**/*"]
}