{
  "name": "fluenttyper",
  "version": "2025.7.1",
  "description": "",
  "type": "module",
  "scripts": {
    "watch": "webpack --config webpack/webpack.dev.js --watch",
    "build": "webpack --config webpack/webpack.prod.js",
    "check": "eslint . && prettier '**/*.{html,css}' --check",
    "lint": "eslint --fix . && prettier '**/*.{html,css,js,ts}' --write",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "update": "ncu -u && npm update",
    "preversion": "npm test",
    "version": "node scripts/update-manifest-version.cjs",
    "postversion": "git push && git push --tags"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "transform": {
      "^.+\\.tsx?$": "ts-jest"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bartekplus/FluentTyper.git"
  },
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/bartekplus/FluentTyper/issues"
  },
  "homepage": "https://github.com/bartekplus/FluentTyper#readme",
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@types/chrome": "0.0.326",
    "@types/dom-navigation": "^1.0.5",
    "@types/jest": "30.0.0",
    "@types/luxon": "^3.6.2",
    "copy-webpack-plugin": "^13.0.0",
    "eslint": "^9.29.0",
    "glob": "11.0.3",
    "globals": "^16.2.0",
    "jest": "30.0.2",
    "jest-environment-jsdom": "^30.0.2",
    "npm-check-updates": "latest",
    "prettier": "3.5.3",
    "rimraf": "6.0.1",
    "ts-jest": "29.4.0",
    "ts-loader": "9.5.2",
    "typescript": "5.8.3",
    "typescript-eslint": "^8.34.1",
    "webpack": "5.99.9",
    "webpack-cli": "6.0.1",
    "webpack-merge": "6.0.1"
  },
  "dependencies": {
    "buffer": "^6.0.3",
    "csv-parse": "^5.6.0",
    "csv-stringify": "^6.5.2",
    "luxon": "^3.6.1"
  }
}
